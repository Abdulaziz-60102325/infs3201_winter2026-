<div style="max-width: 380px; margin: 50px auto; padding: 25px; border: 1px solid #ccc; border-radius: 5px;">
    <h2>Two-Factor Authentication</h2>
    <p>A 6-digit verification code has been sent to your email address.</p>
    <p><em>The code expires in <strong>3 minutes</strong>.</em></p>

    {{#if error}}
        <p style="color: red; padding: 8px; border: 1px solid red; border-radius: 3px;">{{error}}</p>
    {{/if}}

    <form action="/2fa" method="POST">
        <div style="margin-bottom: 15px;">
            <label for="code">Verification Code:</label><br>
            <input
                type="text"
                id="code"
                name="code"
                maxlength="6"
                placeholder="6-digit code"
                autocomplete="off"
                autofocus
                style="width: 100%; padding: 10px; font-size: 20px; letter-spacing: 8px; text-align: center; margin-top: 5px;">
        </div>
        <button type="submit"
            style="width: 100%; padding: 10px; background-color: #007bff; color: white; border: none; border-radius: 3px; cursor: pointer; font-size: 16px;">
            Verify Code
        </button>
    </form>

    <p style="margin-top: 15px; text-align: center;">
        <a href="/login">← Back to Login</a>
    </p>
</div>
